  "description": "Common acronyms across networking, web, security, data, and infrastructure.",
  "cards": [
    { "id": "api", "term": "API", "definition": "Application Programming Interface", "category": "web" },
    { "id": "rest", "term": "REST", "definition": "Representational State Transfer", "category": "web", "example": "An architectural style — not a protocol — built on HTTP verbs and resources." },
    { "id": "grpc", "term": "gRPC", "definition": "google Remote Procedure Call", "category": "web", "example": "HTTP/2-based RPC with Protocol Buffers; stream-friendly." },
    { "id": "http", "term": "HTTP", "definition": "Hypertext Transfer Protocol", "category": "networking" },
    { "id": "https", "term": "HTTPS", "definition": "HTTP Secure (over TLS)", "category": "networking" },
