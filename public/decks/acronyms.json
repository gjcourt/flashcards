    { "id": "ide", "term": "IDE", "definition": "Integrated Development Environment", "category": "tooling" },
    { "id": "sdk", "term": "SDK", "definition": "Software Development Kit", "category": "tooling" },
    { "id": "cdc", "term": "CDC", "definition": "Change Data Capture", "category": "data" },
    { "id": "iam", "term": "IAM", "definition": "Identity and Access Management", "category": "security" },
    { "id": "ci-cd", "term": "CI/CD", "definition": "Continuous Integration / Continuous Delivery (or Deployment)", "category": "infrastructure" }
  ]
}
