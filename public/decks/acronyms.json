    { "id": "udp", "term": "UDP", "definition": "User Datagram Protocol", "category": "networking", "example": "Unreliable, connectionless; lower overhead than TCP." },
    { "id": "ip", "term": "IP", "definition": "Internet Protocol", "category": "networking" },
    { "id": "dns", "term": "DNS", "definition": "Domain Name System", "category": "networking" },
